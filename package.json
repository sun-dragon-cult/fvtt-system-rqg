{
  "private": true,
  "name": "rqg",
  "version": "3.4.8",
  "type": "module",
  "esModuleInterop": true,
  "packageManager": "pnpm@11.6.0",
  "description": "",
  "scripts": {
    "build:dev": "vite build --mode development",
    "build:full": "run-s clean:dist build:system build:packs",
    "build:packs": "tsx buildScripts/buildPacks.ts",
    "build:system": "vite build",
    "build:verify": "run-s build:system typecheck",
    "build": "pnpm run build:full",
    "check:ci": "run-s lint typecheck i18n:audit:en test build:verify",
    "check:prepush": "run-s typecheck i18n:audit:en test",
    "check:quick": "run-s lint test",
    "check": "run-s lint test typecheck",
    "clean:deps": "rimraf node_modules",
    "clean:dist": "rimraf --glob dist src/assets/packs/*",
    "clean": "run-p clean:dist clean:deps",
    "dev": "tsx buildScripts/startDev.ts",
    "foundry": "tsx buildScripts/startFoundry.ts",
    "format": "prettier -w .",
    "i18n:audit:en": "pnpm -s i18n:audit-unused --lang en --fail-on-unused",
    "i18n:audit-unused": "tsx buildScripts/audit-unused-translations.ts",
    "lint:scripts:fix": "eslint . --fix",
    "lint:scripts": "eslint .",
    "lint:styles:fix": "stylelint \"**/*.{css,scss}\" --fix",
    "lint:styles": "stylelint \"**/*.{css,scss}\"",
    "lint:fix": "run-s lint:scripts:fix lint:styles:fix",
    "lint": "run-s lint:scripts lint:styles",
    "preinstall": "node buildScripts/enforce-pnpm.mjs",
    "precommit": "pnpm lint-staged",
    "prepare": "node buildScripts/setup-git-hooks.mjs",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "tsgo": "tsgo",
    "typecheck": "tsc -noEmit"
  },
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "^4.1.10",
    "chalk": "^5.6.2",
    "classic-level": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-tsdoc": "^0.5.2",
    "fs-extra": "^11.3.6",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "globals": "^17.7.0",
    "handlebars": "^4.7.9",
    "js-yaml": "^5.2.1",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "sass-embedded": "^1.100.0",
    "socket.io": "^4.8.3",
    "stylelint": "^17.14.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0",
    "tsx": "^4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-static-copy": "^4.1.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "foswig": "^3.0.1"
  }
}
