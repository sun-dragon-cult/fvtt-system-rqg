# Copy this file to .env.local and adjust values for your machine.
# .env.local is gitignored.

# Foundry target used by pnpm dev when no argument is provided
FOUNDRY_PORT=30014
# FOUNDRY_HOST_NAME=127.0.0.1

# Paths used by pnpm foundry [version]
# Set both APP and DATA for each Foundry version you run.
FOUNDRY_V13_APP=/path/to/foundry-13/FoundryVTT
FOUNDRY_V13_DATA=/path/to/foundry-13/foundrydata
FOUNDRY_V14_APP=/path/to/foundry-14/FoundryVTT
FOUNDRY_V14_DATA=/path/to/foundry-14/foundrydata
