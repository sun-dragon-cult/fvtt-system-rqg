<footer class="form-footer">
  <div class="flexrow flex-wrap gap1rem fullwidth">
    <div class="target-box" data-tooltip="{{localize "RQG.Dialog.Common.TargetChance"}}">
      <i class="fa-solid fa-bullseye"></i><br>
      {{totalChance}}%
    </div>
    {{#each combatManeuverNames}}
      {{#if ../isSelectedWeaponBroken}}
        <button data-combat-maneuver-name="{{this}}" name="combatManeuverRoll" disabled>
          {{this}}
        </button>
      {{else}}
        <button data-combat-maneuver-name="{{this}}" name="combatManeuverRoll">
          {{this}}
        </button>
      {{/if}}
    {{/each}}
  </div>
  {{#if isSelectedWeaponBroken}}
    <div class="footer-message-stack" aria-live="polite">
      <div class="footer-message footer-message-error" role="alert">
        {{localize "RQG.Dialog.Attack.NoValidSkillForWeaponUsage"}}
      </div>
    </div>
  {{/if}}
</footer>
