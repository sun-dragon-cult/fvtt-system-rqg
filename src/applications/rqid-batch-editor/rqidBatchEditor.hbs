<section class="rqid-batch-editor-form">
  <header>
    <h2>{{localize 'RQG.Dialog.BatchRqidEditor.Title'}}</h2>
    <p>{{{summary}}}</p>
  </header>
  <main>
    <ol class="document-list">
      <li class="item flexrow header gap1rem">
        <span class="name">{{localizeitemtype itemType}}</span>
        <div class="value">{{localize 'RQG.Dialog.BatchRqidEditor.ExistingRqidsHeader'}}</div>
        <div class="value">{{localize 'RQG.RQGSystem.Rqid.Id'}}</div>
      </li>

      {{#each itemNamesWithoutRqid}}
        <li class="item document-row flexrow gap1rem" data-name="{{name}}">
          <span class="skill-name">{{name}} </span>
          <div class="value">
            <select class="existing" data-name="{{name}}">
              {{selectOptions @root.existingRqidOptions localize=false}}
            </select>
          </div>
          <div class="value flexrow">
            <span class="rqid-prefix">{{../idPrefix}}</span>
            <input class="rqid-input {{#unless selectedRqidSuffix}}missing{{/unless}}" type="text" value="{{selectedRqidSuffix}}" data-name="{{name}}">
            <button type="button" class="generate-rqid" data-action="generateRqid" data-name="{{name}}" data-tooltip="{{localize "RQG.RQGSystem.Rqid.GenerateDefault"}}" data-tooltip-class="rqid-batch-editor-tooltip" data-tooltip-direction="RIGHT">
              <i class="fas fa-wand-magic-sparkles"></i>
            </button>
          </div>
        </li>
      {{/each}}
    </ol>
  </main>
</section>
