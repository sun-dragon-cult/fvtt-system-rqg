<section class="tab runes-tab-v2" data-group="primary" data-tab="runes">
  {{#if enrichedIncorrectRunes}}<div class="warning">{{{enrichedIncorrectRunes}}}</div>{{/if}}

  <div class="rune-sections">

    {{!-- ========== Elemental Rune Affinities ========== --}}
    {{#unless (isEmptyObject embeddedItems.rune.element)}}
    <div class="rune-section elemental-section">
      <h2>{{localize 'RQG.Actor.Rune.Elemental'}}</h2>

      <div class="elemental-wheel">
        {{!-- Pentagonal layout: 5 elements evenly spaced around Moon center.
             Cycle order (clockwise from top): Fire → Darkness → Water → Earth → Air.
             Each slot handles a missing rune gracefully via {{#with}}. --}}

        {{!-- SVG arrows showing the elemental cycle --}}
        <svg class="wheel-connectors" viewBox="0 0 300 300">
          <defs>
            <marker id="rune-arrow" viewBox="0 0 10 6" refX="10" refY="3"
                    markerWidth="8" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 3 L 0 6 z" />
            </marker>
          </defs>

          {{!-- Pentagram star: minor rune connections (non-adjacent pairs). --}}
          {{#if showUiSection.sorcery}}
          <g class="wheel-pentagram">
            <line x1="150" y1="66"  x2="199" y2="218" />  {{!-- Fire ↔ Water --}}
            <line x1="150" y1="66"  x2="101" y2="218" />  {{!-- Fire ↔ Earth --}}
            <line x1="230" y1="124" x2="101" y2="218" />  {{!-- Darkness ↔ Earth --}}
            <line x1="230" y1="124" x2="70"  y2="124" />  {{!-- Darkness ↔ Air --}}
            <line x1="199" y1="218" x2="70"  y2="124" />  {{!-- Water ↔ Air --}}
          </g>
          {{/if}}

          {{!-- Pentagon cycle arrows: 5 arcs all on the same circle (r=105, center 150,150).
               Arcs are intentionally short: +20° past one vertex to -20° before the next,
               leaving a wider gap around each rune icon/text. --}}
          <g class="wheel-arrows">
            {{!-- Fire(-90°) → Darkness(-18°): -75° to -33° --}}
            <path d="M 177.2,48.6 A 105,105 0 0,1 238.1,92.8" marker-end="url(#rune-arrow)" />
            {{!-- Darkness(-18°) → Water(54°): 10° to 39° (Darkness-side start kept fixed) --}}
            <path d="M 253.4,168.2 A 105,105 0 0,1 231.6,216.1" marker-end="url(#rune-arrow)" />
            {{!-- Water(54°) → Earth(127°): 69° to 112° --}}
            <path d="M 187.6,248.0 A 105,105 0 0,1 110.7,247.4" marker-end="url(#rune-arrow)" />
            {{!-- Earth(127°) → Air(198°): 142° to 171° --}}
            <path d="M 67.3,214.6 A 105,105 0 0,1 46.3,166.4" marker-end="url(#rune-arrow)" />
            {{!-- Air(198°) → Fire(270°): 213° to 255° --}}
            <path d="M 61.9,92.8 A 105,105 0 0,1 122.8,48.6" marker-end="url(#rune-arrow)" />
          </g>
        </svg>

        <div class="wheel-slot wheel-fire">
          {{#with embeddedItems.rune.element.fire}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../elementRuneVisuals.fire.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-darkness">
          {{#with embeddedItems.rune.element.darkness}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../elementRuneVisuals.darkness.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-water">
          {{#with embeddedItems.rune.element.water}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../elementRuneVisuals.water.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-earth">
          {{#with embeddedItems.rune.element.earth}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../elementRuneVisuals.earth.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-air">
          {{#with embeddedItems.rune.element.air}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../elementRuneVisuals.air.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-moon">
          {{#with embeddedItems.rune.element.moon}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../elementRuneVisuals.moon.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>
      </div>
    </div>
    {{/unless}}

    {{!-- ========== Power Rune Affinities (opposed pairs) ========== --}}
    {{#if powerRunePairs.length}}
    <div class="rune-section power-section">
      <h2>{{localize 'RQG.Actor.Rune.Power'}}</h2>

      <div class="opposed-pairs">
        {{#each powerRunePairs}}
        <div class="opposed-row">
          <div class="rune-slot">
            {{#with this.left}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../leftCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
          <div class="balance-bar">
            <div class="balance-marker" style="left: {{this.markerPercent}}%"></div>
          </div>
          <div class="rune-slot">
            {{#with this.right}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../rightCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- ========== Form Rune Affinities ========== --}}
    {{#unless (isEmptyObject embeddedItems.rune.form)}}
    <div class="rune-section form-section">
      <h2>{{localize "RQG.Actor.Rune.Form"}}</h2>

      {{!-- Opposed form rune pairs --}}
      {{#if formRunePairs.length}}
      <div class="opposed-pairs">
        {{#each formRunePairs}}
        <div class="opposed-row">
          <div class="rune-slot">
            {{#with this.left}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../leftCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
          <div class="balance-bar">
            <div class="balance-marker" style="left: {{this.markerPercent}}%"></div>
          </div>
          <div class="rune-slot">
            {{#with this.right}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune {{../rightCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{!-- Standalone form runes (no opposing rune defined) --}}
      {{#each formRuneStandalone}}
      <div class="rune rune-card standalone contextmenu item" data-item-id="{{id}}">
        {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
        <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
        {{#edit-mode ../system.editMode "all"}}
        <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
        {{else}}
        <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
              data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
        {{/edit-mode}}
      </div>
      {{/each}}
    </div>
    {{/unless}}

    {{!-- ========== Condition Runes ========== --}}
    {{#unless (isEmptyObject embeddedItems.rune.condition)}}
    <div class="rune-section condition-section">
      <h2>{{localize "RQG.Actor.Rune.Condition"}}</h2>
      <div class="rune-card-row">
        {{#each embeddedItems.rune.condition}}
        <div class="rune rune-card standalone contextmenu item" data-item-id="{{id}}">
          {{#if @root.isGM}}<span class="item-drag-handle item draggable" data-tooltip data-item-drag-handle data-item-id="{{id}}"><span class="grip-icon"></span></span>{{/if}}<img class="rune" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
          <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
          {{#edit-mode ../system.editMode "all"}}
          <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
          {{else}}
          <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
          {{/edit-mode}}
        </div>
        {{/each}}
      </div>
    </div>
    {{/unless}}

  </div>

  {{!-- ========== Invalid / duplicate runes (debug) ========== --}}
  {{#unless (isEmptyObject embeddedItems.rune.invalid)}}
    <div class="grid rune item-list">
      <h2 class="fullrow">🐛 Extra / Duplicate Runes</h2>
      {{#each embeddedItems.rune.invalid}}
        {{> actorRuneGrid
          rune=this
          wizard=../wizard
          forChoice=../forChoice
          checkedProperty=../checkedProperty
          editMode=../system.editMode}}
      {{/each}}
    </div>
  {{/unless}}
</section>
