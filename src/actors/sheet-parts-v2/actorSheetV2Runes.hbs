<section class="tab runes-tab-v2" data-group="primary" data-tab="runes">
  {{#if enrichedIncorrectRunes}}<div class="warning">{{{enrichedIncorrectRunes}}}</div>{{/if}}

  <div class="rune-sections">

    {{!-- ========== Elemental Rune Affinities ========== --}}
    {{#unless (isEmptyObject embeddedItems.rune.element)}}
    <div class="rune-section elemental-section">
      <h2>{{localize 'RQG.Actor.Rune.Elemental'}}</h2>

      <div class="elemental-wheel">
        {{!-- Pentagonal layout: 5 elements evenly spaced around Moon center.
             Cycle order (clockwise from top): Fire → Darkness → Water → Earth → Air.
             Each slot handles a missing rune gracefully via {{#with}}. --}}

        {{!-- SVG arrows showing the elemental cycle --}}
        <svg class="wheel-connectors" viewBox="0 0 300 300">
          <defs>
            <marker id="rune-arrow" viewBox="0 0 10 6" refX="9" refY="3"
                    markerWidth="8" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 3 L 0 6 z" />
            </marker>
          </defs>

          {{!-- Pentagram star: minor rune connections (non-adjacent pairs).
               Rendered first so they sit behind the cycle arrows and below the Moon rune.
               Vertices: Fire(150,45) Darkness(249,117) Water(216,222) Earth(84,222) Air(51,117) --}}
          <g class="wheel-star">
            <line x1="150" y1="45" x2="216" y2="222" />  {{!-- Fire ↔ Water --}}
            <line x1="150" y1="45" x2="84"  y2="222" />  {{!-- Fire ↔ Earth --}}
            <line x1="249" y1="117" x2="84" y2="222" />  {{!-- Darkness ↔ Earth --}}
            <line x1="249" y1="117" x2="51" y2="117" />  {{!-- Darkness ↔ Air --}}
            <line x1="216" y1="222" x2="51" y2="117" />  {{!-- Water ↔ Air --}}
          </g>

          {{!-- Regular pentagon: center(150,150), radius 105 in 300×300 viewBox.
               Arrow endpoints offset ±15° from each vertex along the circle.
               Cycle: Fire → Darkness → Water → Earth → Air → Fire --}}
          <g class="wheel-arrows">
            {{!-- Fire→Darkness --}}
            <path d="M 177,49 A 105,105 0 0,1 238,93" marker-end="url(#rune-arrow)" />
            {{!-- Darkness→Water --}}
            <path d="M 255,145 A 105,105 0 0,1 232,216" marker-end="url(#rune-arrow)" />
            {{!-- Water→Earth --}}
            <path d="M 188,248 A 105,105 0 0,1 112,248" marker-end="url(#rune-arrow)" />
            {{!-- Earth→Air --}}
            <path d="M 68,216 A 105,105 0 0,1 45,145" marker-end="url(#rune-arrow)" />
            {{!-- Air→Fire --}}
            <path d="M 62,93 A 105,105 0 0,1 123,49" marker-end="url(#rune-arrow)" />
          </g>
        </svg>

        <div class="wheel-slot wheel-fire">
          {{#with embeddedItems.rune.element.fire}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            <img class="rune {{../elementRuneVisuals.fire.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-darkness">
          {{#with embeddedItems.rune.element.darkness}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            <img class="rune {{../elementRuneVisuals.darkness.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-water">
          {{#with embeddedItems.rune.element.water}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            <img class="rune {{../elementRuneVisuals.water.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-earth">
          {{#with embeddedItems.rune.element.earth}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            <img class="rune {{../elementRuneVisuals.earth.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-air">
          {{#with embeddedItems.rune.element.air}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            <img class="rune {{../elementRuneVisuals.air.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>

        <div class="wheel-slot wheel-moon">
          {{#with embeddedItems.rune.element.moon}}
          <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
            <img class="rune {{../elementRuneVisuals.moon.cls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
            <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
            {{#edit-mode ../system.editMode "all"}}
            <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
            {{else}}
            <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                  data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
            {{/edit-mode}}
          </div>
          {{/with}}
        </div>
      </div>
    </div>
    {{/unless}}

    {{!-- ========== Power Rune Affinities (opposed pairs) ========== --}}
    {{#if powerRunePairs.length}}
    <div class="rune-section power-section">
      <h2>{{localize 'RQG.Actor.Rune.Power'}}</h2>

      <div class="opposed-pairs">
        {{#each powerRunePairs}}
        <div class="opposed-row">
          <div class="rune-slot">
            {{#with this.left}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              <img class="rune {{../leftCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
          <div class="balance-bar">
            <div class="balance-marker" style="left: {{this.markerPercent}}%"></div>
          </div>
          <div class="rune-slot">
            {{#with this.right}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              <img class="rune {{../rightCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- ========== Form Rune Affinities ========== --}}
    {{#unless (isEmptyObject embeddedItems.rune.form)}}
    <div class="rune-section form-section">
      <h2>{{localize "RQG.Actor.Rune.Form"}}</h2>

      {{!-- Opposed form rune pairs --}}
      {{#if formRunePairs.length}}
      <div class="opposed-pairs">
        {{#each formRunePairs}}
        <div class="opposed-row">
          <div class="rune-slot">
            {{#with this.left}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              <img class="rune {{../leftCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
          <div class="balance-bar">
            <div class="balance-marker" style="left: {{this.markerPercent}}%"></div>
          </div>
          <div class="rune-slot">
            {{#with this.right}}
            <div class="rune rune-card contextmenu item" data-item-id="{{id}}">
              <img class="rune {{../rightCls}}" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
              <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
              {{#edit-mode ../../system.editMode "all"}}
              <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
              {{else}}
              <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                    data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
              {{/edit-mode}}
            </div>
            {{/with}}
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

      {{!-- Standalone form runes (no opposing rune defined) --}}
      {{#each formRuneStandalone}}
      <div class="rune rune-card standalone contextmenu item" data-item-id="{{id}}">
        <img class="rune" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
        <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
        {{#edit-mode ../system.editMode "all"}}
        <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
        {{else}}
        <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
              data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
        {{/edit-mode}}
      </div>
      {{/each}}
    </div>
    {{/unless}}

    {{!-- ========== Condition Runes ========== --}}
    {{#unless (isEmptyObject embeddedItems.rune.condition)}}
    <div class="rune-section condition-section">
      <h2>{{localize "RQG.Actor.Rune.Condition"}}</h2>
      <div class="rune-card-row">
        {{#each embeddedItems.rune.condition}}
        <div class="rune rune-card standalone contextmenu item" data-item-id="{{id}}">
          <img class="rune" src="{{img}}" {{#if system.descriptionRqidLink.rqid}}data-rqid-link="{{system.descriptionRqidLink.rqid}}"{{/if}}>
          <span class="rune-name" data-item-id="{{id}}" data-item-roll data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.rune}}</span>
          {{#edit-mode ../system.editMode "all"}}
          <input type="number" data-rune-grid-edit data-item-id="{{id}}" value="{{system.chance}}">
          {{else}}
          <span class="rune-chance {{experiencedclass uuid}}" data-item-id="{{id}}" data-item-roll
                data-tooltip="{{localize "RQG.Game.RollTitle"}}">{{system.chance}}%</span>
          {{/edit-mode}}
        </div>
        {{/each}}
      </div>
    </div>
    {{/unless}}

  </div>

  {{!-- ========== Invalid / duplicate runes (debug) ========== --}}
  {{#unless (isEmptyObject embeddedItems.rune.invalid)}}
    <div class="grid rune item-list">
      <h2 class="fullrow">🐛 Extra / Duplicate Runes</h2>
      {{#each embeddedItems.rune.invalid}}
        {{> actorRuneGrid
          rune=this
          wizard=../wizard
          forChoice=../forChoice
          checkedProperty=../checkedProperty
          editMode=../system.editMode}}
      {{/each}}
    </div>
  {{/unless}}
</section>
