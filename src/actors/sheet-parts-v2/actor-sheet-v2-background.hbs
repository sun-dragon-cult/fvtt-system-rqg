<section class="tab background-tab-v2" data-group="primary" data-tab="background">

  <div class="background-fieldsets">

    {{!-- Base Data --}}
    <fieldset>
      <legend>{{localize "RQG.Actor.Background.BaseData"}}</legend>
      <div class="key-value-grid">
        {{#edit-mode system.editMode "all"}}
          <label for="birthyear-{{id}}">{{localize "RQG.Actor.Background.BirthYear"}}</label>
          <input id="birthyear-{{id}}" name="system.background.birthyear"
            value="{{system.background.birthyear}}" type="number" min="0" max="9999" />
        {{else}}
          {{#if system.background.birthyear}}
            <label>{{localize "RQG.Actor.Background.BirthYear"}}</label>
            <span>{{system.background.birthyear}}</span>
          {{/if}}
        {{/edit-mode}}

        {{#edit-mode system.editMode "all"}}
          <label for="age-{{id}}">{{localize "RQG.Actor.Background.Age"}}</label>
          <input id="age-{{id}}" name="system.background.age"
            value="{{system.background.age}}" type="number" min="0" max="999" />
        {{else}}
          {{#if system.background.age}}
            <label>{{localize "RQG.Actor.Background.Age"}}</label>
            <span>{{system.background.age}}</span>
          {{/if}}
        {{/edit-mode}}

        {{#edit-mode system.editMode "all"}}
          <label for="gender-{{id}}">{{localize "RQG.Actor.Background.Gender"}}</label>
          <input id="gender-{{id}}" name="system.background.gender"
            value="{{system.background.gender}}" type="text" />
        {{else}}
          {{#if system.background.gender}}
            <label>{{localize "RQG.Actor.Background.Gender"}}</label>
            <span>{{system.background.gender}}</span>
          {{/if}}
        {{/edit-mode}}

        {{#edit-mode system.editMode "all"}}
          <label for="species-{{id}}">{{localize "RQG.Actor.Background.Species"}}</label>
          <input id="species-{{id}}" name="system.background.species"
            value="{{system.background.species}}" type="text" />
        {{else}}
          {{#if actorWizardFeatureFlag}}
            {{#unless system.background.speciesRqidLink.rqid}}
              {{#if system.background.species}}
                <label>{{localize "RQG.Actor.Background.Species"}}</label>
                <span>{{system.background.species}}</span>
              {{/if}}
            {{/unless}}
          {{else}}
            {{#if system.background.species}}
              <label>{{localize "RQG.Actor.Background.Species"}}</label>
              <span>{{system.background.species}}</span>
            {{/if}}
          {{/if}}
        {{/edit-mode}}

        {{#if actorWizardFeatureFlag}}
          {{#edit-mode system.editMode "all"}}
            <label></label>
            {{> rqidLinkDropzone
              rqidLink=system.background.speciesRqidLink
              dropzoneData="background.speciesRqidLink"
              dropDocumentNames="JournalEntry, JournalEntryPage"
              showDeleteFromPropertyName="background.speciesRqidLink"
              showInfoCircleConnect="RQG.Item.RqgItem.ShowInfoCircle.DropToConnectJournal"
              showInfoCircleReplace="RQG.Item.RqgItem.ShowInfoCircle.DropToReplaceJournal"
            }}
          {{else}}
            {{#if system.background.speciesRqidLink.rqid}}
              <label>{{localize "RQG.Actor.Background.Species"}}</label>
              {{> rqidLink rqidLink=system.background.speciesRqidLink}}
            {{/if}}
          {{/edit-mode}}
        {{/if}}
      </div>
    </fieldset>

    {{!-- Origin (plain text, non-wizard) --}}
    {{#unless actorWizardFeatureFlag}}
      <fieldset>
        <legend>{{localize "RQG.Actor.Background.Origin"}}</legend>
        <div class="key-value-grid">
          {{#edit-mode system.editMode "all"}}
            <label for="homeland-{{id}}">{{localize "RQG.Actor.Background.Homeland.Heading"}}</label>
            <input id="homeland-{{id}}" name="system.background.homeland"
              value="{{system.background.homeland}}" type="text" list="homelands-{{id}}" />
            <datalist id="homelands-{{id}}">
              {{#each homelands}}
                <option value="{{localize (concat "RQG.Actor.Background.Homeland." this)}}"></option>
              {{/each}}
            </datalist>
          {{else}}
            {{#if system.background.homeland}}
              <label>{{localize "RQG.Actor.Background.Homeland.Heading"}}</label>
              <span>{{system.background.homeland}}</span>
            {{/if}}
          {{/edit-mode}}

          {{#edit-mode system.editMode "all"}}
            <label for="town-{{id}}">{{localize "RQG.Actor.Background.TownHomeArea"}}</label>
            <input id="town-{{id}}" name="system.background.town"
              value="{{system.background.town}}" type="text" />
          {{else}}
            {{#if system.background.town}}
              <label>{{localize "RQG.Actor.Background.TownHomeArea"}}</label>
              <span>{{system.background.town}}</span>
            {{/if}}
          {{/edit-mode}}

          {{#edit-mode system.editMode "all"}}
            <label for="tribe-{{id}}">{{localize "RQG.Actor.Background.Tribe"}}</label>
            <input id="tribe-{{id}}" name="system.background.tribe"
              value="{{system.background.tribe}}" type="text" />
          {{else}}
            {{#if system.background.tribe}}
              <label>{{localize "RQG.Actor.Background.Tribe"}}</label>
              <span>{{system.background.tribe}}</span>
            {{/if}}
          {{/edit-mode}}

          {{#edit-mode system.editMode "all"}}
            <label for="clan-{{id}}">{{localize "RQG.Actor.Background.Clan"}}</label>
            <input id="clan-{{id}}" name="system.background.clan"
              value="{{system.background.clan}}" type="text" />
          {{else}}
            {{#if system.background.clan}}
              <label>{{localize "RQG.Actor.Background.Clan"}}</label>
              <span>{{system.background.clan}}</span>
            {{/if}}
          {{/edit-mode}}
        </div>
      </fieldset>
    {{/unless}}

    {{!-- Circumstance --}}
    <fieldset>
      <legend>{{localize "RQG.Actor.Background.Circumstance"}}</legend>
      <div class="key-value-grid">
        {{#edit-mode system.editMode "all"}}
          <div class="reputation-row">
            <div data-reputation-roll class="reputation-label">
              <img src="{{defaultItemIconSrc 'reputation'}}" class="item" />
              <label for="reputation-{{id}}">{{localize "RQG.Actor.Background.Reputation"}}</label>
            </div>
            <div>
              <input id="reputation-{{id}}" name="system.background.reputation"
                value="{{system.background.reputation}}" type="number" min="0" max="999" />%
            </div>
          </div>
        {{else}}
          <div class="reputation-row">
            <div data-reputation-roll class="reputation-label">
              <img src="{{defaultItemIconSrc 'reputation'}}" class="item" />
              <label>{{localize "RQG.Actor.Background.Reputation"}}</label>
            </div>
            <div data-reputation-roll>{{system.background.reputation}}%</div>
          </div>
        {{/edit-mode}}

        {{#edit-mode system.editMode "all"}}
          <label for="standard-of-living-{{id}}">{{localize "RQG.Actor.Background.StandardOfLiving"}}</label>
          <input id="standard-of-living-{{id}}" name="system.background.standardOfLiving"
            value="{{system.background.standardOfLiving}}" type="text" />
        {{else}}
          {{#if system.background.standardOfLiving}}
            <label>{{localize "RQG.Actor.Background.StandardOfLiving"}}</label>
            <span>{{system.background.standardOfLiving}}</span>
          {{/if}}
        {{/edit-mode}}

        {{#edit-mode system.editMode "all"}}
          <label for="occupation-{{id}}">{{localize "RQG.Actor.Background.Occupation.Heading"}}</label>
          <select id="occupation-{{id}}" name="system.background.occupation">
            {{selectOptions occupationOptions selected=system.background.occupation}}
          </select>
        {{else}}
          {{#if actorWizardFeatureFlag}}
            {{#unless system.background.currentOccupationRqidLink.rqid}}
              {{#if system.background.occupation}}
                <label>{{localize "RQG.Actor.Background.Occupation.Heading"}}</label>
                <span>{{localize (concat "RQG.Actor.Background.Occupation." system.background.occupation)}}</span>
              {{/if}}
            {{/unless}}
          {{else}}
            {{#if system.background.occupation}}
              <label>{{localize "RQG.Actor.Background.Occupation.Heading"}}</label>
              <span>{{localize (concat "RQG.Actor.Background.Occupation." system.background.occupation)}}</span>
            {{/if}}
          {{/if}}
        {{/edit-mode}}

        {{#if actorWizardFeatureFlag}}
          {{#edit-mode system.editMode "all"}}
            <label></label>
            {{> rqidLinkDropzone
              rqidLink=system.background.currentOccupationRqidLink
              dropzoneData="background.currentOccupationRqidLink"
              dropDocumentNames="Item"
              dropDocumentTypes="occupation"
              showDeleteFromPropertyName="background.currentOccupationRqidLink"
              showInfoCircleConnect="RQG.Item.RqgItem.ShowInfoCircle.DropToConnectOccupation"
              showInfoCircleReplace="RQG.Item.RqgItem.ShowInfoCircle.DropToReplaceOccupation"
            }}
          {{else}}
            {{#if system.background.currentOccupationRqidLink.rqid}}
              <label>{{localize "RQG.Actor.Background.Occupation.Heading"}}</label>
              {{> rqidLink rqidLink=system.background.currentOccupationRqidLink}}
            {{/if}}
          {{/edit-mode}}
        {{/if}}

        {{#edit-mode system.editMode "all"}}
          <label for="base-income-{{id}}">{{localize "RQG.Actor.Background.BaseIncome"}}</label>
          <div>
            <input id="base-income-{{id}}" name="system.background.baseIncome"
              value="{{system.background.baseIncome}}" type="number" min="0" max="99999999" />
            ({{localize "RQG.Item.Gear.LunarsAbbr"}})
          </div>
        {{else}}
          {{#if system.background.baseIncome}}
            <label>{{localize "RQG.Actor.Background.BaseIncome"}}</label>
            <span>{{system.background.baseIncome}} ({{localize "RQG.Item.Gear.LunarsAbbr"}})</span>
          {{/if}}
        {{/edit-mode}}

        {{#edit-mode system.editMode "all"}}
          <label for="ransom-{{id}}">{{localize "RQG.Actor.Background.Ransom"}}</label>
          <div>
            <input id="ransom-{{id}}" name="system.background.ransom"
              value="{{system.background.ransom}}" type="number" min="0" max="99999999" />
            ({{localize "RQG.Item.Gear.LunarsAbbr"}})
          </div>
          <label for="ransom-details-{{id}}">{{localize "RQG.Actor.Background.RansomDetails"}}</label>
          <input id="ransom-details-{{id}}" name="system.background.ransomDetails"
            value="{{system.background.ransomDetails}}" type="text" />
        {{else}}
          {{#if system.background.ransom}}
            <label>{{localize "RQG.Actor.Background.Ransom"}}</label>
            <span>{{system.background.ransom}} ({{localize "RQG.Item.Gear.LunarsAbbr"}})
              {{system.background.ransomDetails}}</span>
          {{/if}}
        {{/edit-mode}}
      </div>
    </fieldset>

    {{!-- Origin (wizard rqid links) --}}
    {{#if actorWizardFeatureFlag}}
      <fieldset>
        <legend>{{localize "RQG.Actor.Background.Origin"}}</legend>
        <div class="key-value-grid">
          <label>{{localize "RQG.Actor.Background.Homeland.Heading"}}</label>
          <div class="rqid-dropzone-wrap">
            {{#edit-mode system.editMode "all"}}
              {{> rqidLinkDropzone
                rqidLink=system.background.homelandJournalRqidLink
                dropzoneData="background.homelandJournalRqidLink"
                dropDocumentNames="JournalEntry, JournalEntryPage"
                showDeleteFromPropertyName="background.homelandJournalRqidLink"
                showInfoCircleConnect="RQG.Item.RqgItem.ShowInfoCircle.DropToConnectJournal"
              }}
              {{#unless system.background.homelandJournalRqidLink.rqid}}
                <input
                  name="system.background.homeland"
                  value="{{system.background.homeland}}"
                  type="text"
                />
              {{/unless}}
            {{else}}
              {{#if system.background.homelandJournalRqidLink.rqid}}
                {{> rqidLink rqidLink=system.background.homelandJournalRqidLink}}
              {{else}}
                {{#if system.background.homeland}}
                  <span class="rqid-fallback-text">{{system.background.homeland}}</span>
                {{/if}}
              {{/if}}
            {{/edit-mode}}
          </div>

          <label>{{localize "RQG.Actor.Background.Region"}}</label>
          <div class="rqid-dropzone-wrap">
            {{#edit-mode system.editMode "all"}}
              {{> rqidLinkDropzone
                rqidLink=system.background.regionJournalRqidLink
                dropzoneData="background.regionJournalRqidLink"
                dropDocumentNames="JournalEntry, JournalEntryPage"
                showDeleteFromPropertyName="background.regionJournalRqidLink"
                showInfoCircleConnect="RQG.Item.RqgItem.ShowInfoCircle.DropToConnectJournal"
              }}
              {{#unless system.background.regionJournalRqidLink.rqid}}
                <input
                  name="system.background.town"
                  value="{{system.background.town}}"
                  type="text"
                />
              {{/unless}}
            {{else}}
              {{#if system.background.regionJournalRqidLink.rqid}}
                {{> rqidLink rqidLink=system.background.regionJournalRqidLink}}
              {{else}}
                {{#if system.background.town}}
                  <span class="rqid-fallback-text">{{system.background.town}}</span>
                {{/if}}
              {{/if}}
            {{/edit-mode}}
          </div>

          <label>{{localize "RQG.Actor.Background.Cultures"}}</label>
          {{#edit-mode system.editMode "all"}}
            {{> rqidLinkArrayDropzone
              rqidLinkArray=system.background.cultureJournalRqidLinks
              dropzoneData="background.cultureJournalRqidLinks"
              dropDocumentNames="JournalEntry, JournalEntryPage"
              showDeleteFromPropertyName="background.cultureJournalRqidLinks"
              showInfoCircleConnect="RQG.Item.RqgItem.ShowInfoCircle.DropToConnectJournal"
            }}
          {{else}}
            {{#if system.background.cultureJournalRqidLinks.length}}
              <div class="rqid-area">
                {{#each system.background.cultureJournalRqidLinks}}
                  {{> rqidLink rqidLink=this}}
                {{/each}}
              </div>
            {{/if}}
          {{/edit-mode}}

          <label>{{localize "RQG.Actor.Background.Tribes"}}</label>
          <div class="rqid-dropzone-wrap">
            {{#edit-mode system.editMode "all"}}
              {{> rqidLinkArrayDropzone
                rqidLinkArray=system.background.tribeJournalRqidLinks
                dropzoneData="background.tribeJournalRqidLinks"
                dropDocumentNames="JournalEntry, JournalEntryPage"
                showDeleteFromPropertyName="background.tribeJournalRqidLinks"
                showInfoCircleConnect="RQG.Item.RqgItem.ShowInfoCircle.DropToConnectJournal"
              }}
              {{#unless system.background.tribeJournalRqidLinks.length}}
                <input
                  name="system.background.tribe"
                  value="{{system.background.tribe}}"
                  type="text"
                />
              {{/unless}}
            {{else}}
              {{#if system.background.tribeJournalRqidLinks.length}}
                <div class="rqid-area">
                  {{#each system.background.tribeJournalRqidLinks}}
                    {{> rqidLink rqidLink=this}}
                  {{/each}}
                </div>
              {{else}}
                {{#if system.background.tribe}}
                  <span class="rqid-fallback-text">{{system.background.tribe}}</span>
                {{/if}}
              {{/if}}
            {{/edit-mode}}
          </div>

          <label>{{localize "RQG.Actor.Background.Clans"}}</label>
          <div class="rqid-dropzone-wrap">
            {{#edit-mode system.editMode "all"}}
              {{> rqidLinkArrayDropzone
                rqidLinkArray=system.background.clanJournalRqidLinks
                dropzoneData="background.clanJournalRqidLinks"
                dropDocumentNames="JournalEntry, JournalEntryPage"
                showDeleteFromPropertyName="background.clanJournalRqidLinks"
                showInfoCircleConnect="RQG.Item.RqgItem.ShowInfoCircle.DropToConnectJournal"
              }}
              {{#unless system.background.clanJournalRqidLinks.length}}
                <input
                  name="system.background.clan"
                  value="{{system.background.clan}}"
                  type="text"
                />
              {{/unless}}
            {{else}}
              {{#if system.background.clanJournalRqidLinks.length}}
                <div class="rqid-area">
                  {{#each system.background.clanJournalRqidLinks}}
                    {{> rqidLink rqidLink=this}}
                  {{/each}}
                </div>
              {{else}}
                {{#if system.background.clan}}
                  <span class="rqid-fallback-text">{{system.background.clan}}</span>
                {{/if}}
              {{/if}}
            {{/edit-mode}}
          </div>
        </div>
      </fieldset>
    {{/if}}

  </div>{{!-- .background-fieldsets --}}

  {{!-- Biography rich text editor --}}
  <prose-mirror
    name="system.background.biography"
    value="{{system.background.biography}}"
    toggled
  >{{{enrichedBiography}}}</prose-mirror>

</section>
