<div data-item-uuid="{{uuid}}">
  <h2>
    <span class="flex-row">
    {{localize "RQG.Foundry.ActiveEffect.Header"}}
      <a data-tooltip="{{localize "RQG.Foundry.ActiveEffect.AddEffectTitle"}}" data-item-effect-add><i
        class="fas fa-plus"></i></a>
    </span>
  </h2>

  <table>
    <thead>
    <tr>
      <th class="text-left">{{localize "RQG.Foundry.ActiveEffect.Label"}}</th>
      <th class="text-center">{{localize "RQG.Foundry.ActiveEffect.Disabled"}}</th>
      <th class="text-center">{{localize "RQG.Foundry.ActiveEffect.MatchSuspensionToEquippedStatus"}}</th>
      <th class="text-center">{{localize "RQG.Foundry.ActiveEffect.Start"}}</th>
      <th class="text-center">{{localize "RQG.Foundry.ActiveEffect.Duration"}}</th>
      <th class="text-left">{{localize "RQG.Foundry.ActiveEffect.KeyValueMode"}}</th>
      <th class="text-left"></th>
    </tr>
    </thead>
    {{#each effects}}
      <tbody data-effect-uuid="{{uuid}}">
      <tr>
        <td><a data-item-effect-edit>{{name}}</a></td>
        <td class="text-center"><a data-item-effect-edit>{{yes-no disabled}}</a></td>
        <td class="text-center"><a data-item-effect-edit>{{yes-no system.matchSuspensionToEquippedStatus}}</a></td>
        <td class="text-center"><a data-item-effect-edit>{{activeEffectStart this}}</a></td>
        {{#if (activeEffectHasEarlyExpiryWarning this)}}
          <td class="text-center"><a data-item-effect-edit data-tooltip="{{activeEffectEarlyExpiryWarningTooltip this}}">
            {{activeEffectDuration this}}
            <span class="active-effect-warning-badge">{{localize "RQG.Foundry.ActiveEffect.EarlyExpiryWarningBadge"}}</span>
          </a></td>
        {{else}}
          <td class="text-center"><a data-item-effect-edit>{{activeEffectDuration this}}</a></td>
        {{/if}}
        <td><a data-item-effect-edit>
          {{#each changes}}
            {{key}} - {{value}} - {{localizeActiveEffectType type}}<br>
          {{/each}}</a></td>
        <td class="text-right"><a data-tooltip="Delete Effect" data-item-effect-delete><i class="fas fa-trash"></i></a>
        </td> 
      </tr>

      </tbody>
    {{/each}}
  </table>
</div>
